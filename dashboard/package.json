{
  "name": "ecodb-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "EcoDB knowledge dashboard — Electron + React",
  "author": "josortmel",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "test": "vitest run",
    "package": "npm run build && electron-builder --win --publish never",
    "package:dir": "npm run build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "d3-force": "^3.0.0",
    "electron-store": "^8.2.0",
    "i18next": "^23.16.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^15.7.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@fontsource/dm-mono": "^5.1.0",
    "@fontsource/hanken-grotesk": "^5.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.6"
  },
  "build": {
    "productName": "EcoDB",
    "appId": "com.ecoconsulting.ecodb",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
