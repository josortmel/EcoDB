# EcoDB Configuration
# Copy to .env and fill in values, or run ./scripts/setup.sh to auto-generate.
# .env is in .gitignore — NEVER commit secrets to the repo.

# ─── Database ───────────────────────────────────────────────────────
ECODB_DB_PASSWORD=<generated-by-setup.sh>

# ─── Environment ────────────────────────────────────────────────────
# "development" or "production". In production, secrets below MUST be
# real random values (not the dev defaults). The API refuses to start
# in production with dev/empty secrets.
ECODB_ENV=development

# ─── Auth secrets ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ECODB_JWT_SECRET=<generated-by-setup.sh>
ECODB_API_KEY_PEPPER=<generated-by-setup.sh>

# ─── CORS ───────────────────────────────────────────────────────────
ECODB_CORS_ORIGINS=http://localhost:8080,http://localhost:8091

# ─── API key ────────────────────────────────────────────────────────
# First-time: leave empty, run `docker compose up`, then generate with:
#   docker exec ecodb-api python bootstrap_first_apikey.py
# Paste the output here and restart the MCP service.
ECODB_API_KEY=

# ─── HuggingFace cache (optional) ──────────────────────────────────
# Bind-mount path for HF model cache. Speeds up rebuilds by reusing
# downloaded models. Leave unset to use a Docker named volume instead.
# HF_CACHE_PATH=/path/to/your/.cache/huggingface

# ─── LLM provider (optional) ───────────────────────────────────────
# "local" (default, uses llama.cpp), "anthropic", or "deepseek".
# Local requires the with-llm Docker profile and a GGUF model in models/.
# ECODB_LLM_PROVIDER=local
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_URL=https://api.deepseek.com

# ─── LLM threads (for local llama.cpp) ─────────────────────────────
# LLM_THREADS=4
